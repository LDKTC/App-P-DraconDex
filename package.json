{
  "name": "DraconDex",
  "version": "1.2.2",
  "description": "Novel data management app",
  "main": "main.js",
  "scripts": {
    "start": "node ./start.js",
    "postinstall": "node ./ensure-electron.js && electron-rebuild -f -w better-sqlite3",
    "build:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.dracondex.app",
    "productName": "DraconDex",
    "asar": true,
    "directories": {
      "output": "DragonDexPortable"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "renderer.js",
      "style.css",
      "database.js",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
